# ---- 1) Construire chaque proxy avec une colonne "type" ----

# Proxy mix (50% R&D + 50% brevets)
proxy_mix <- rd %>%
  inner_join(brevets, by = c("TIME_PERIOD", "geo")) %>%
  rename(
    rd_valeur      = `valeur normalisée`,
    brevets_valeur = `obs normalisées brevets`
  ) %>%
  mutate(
    rd_norm      = as.numeric(scale(rd_valeur)),
    brevets_norm = as.numeric(scale(brevets_valeur)),
    proxy        = 0.5 * rd_norm + 0.5 * brevets_norm,
    type         = "Mix (R&D + brevets)"
  ) %>%
  group_by(TIME_PERIOD) %>%
  summarise(proxy = mean(proxy, na.rm = TRUE), type = first(type), .groups = "drop")

# Proxy R&D seul
proxy_rd <- rd %>%
  inner_join(brevets, by = c("TIME_PERIOD", "geo")) %>%
  rename(
    rd_valeur      = `valeur normalisée`,
    brevets_valeur = `obs normalisées brevets`
  ) %>%
  mutate(
    rd_norm      = as.numeric(scale(rd_valeur)),
    brevets_norm = as.numeric(scale(brevets_valeur)),
    proxy        = 1 * rd_norm + 0 * brevets_norm,
    type         = "R&D seul"
  ) %>%
  group_by(TIME_PERIOD) %>%
  summarise(proxy = mean(proxy, na.rm = TRUE), type = first(type), .groups = "drop")

# Proxy brevets seul
proxy_brevets <- rd %>%
  inner_join(brevets, by = c("TIME_PERIOD", "geo")) %>%
  rename(
    rd_valeur      = `valeur normalisée`,
    brevets_valeur = `obs normalisées brevets`
  ) %>%
  mutate(
    rd_norm      = as.numeric(scale(rd_valeur)),
    brevets_norm = as.numeric(scale(brevets_valeur)),
    proxy        = 0 * rd_norm + 1 * brevets_norm,
    type         = "Brevets seuls"
  ) %>%
  group_by(TIME_PERIOD) %>%
  summarise(proxy = mean(proxy, na.rm = TRUE), type = first(type), .groups = "drop")

# ---- 2) Fusionner les trois proxies ----
data_plot <- bind_rows(proxy_mix, proxy_rd, proxy_brevets)

# Vérification rapide
head(data_plot)

# ---- 3) Graphique comparatif ----
ggplot(data_plot, aes(x = TIME_PERIOD, y = proxy, color = type)) +
  geom_line(size = 1.1) +
  geom_point(size = 2, alpha = 0.7) +
  labs(
    title = "Comparaison des proxies Innovation UE27",
    x = "Année", y = "Proxy (normalisé)",
    color = "Type de proxy"
  ) +
  theme_minimal() +
  scale_x_continuous(breaks = seq(min(data_plot$TIME_PERIOD),
                                  max(data_plot$TIME_PERIOD), by = 2)) +
  theme(legend.position = "bottom")
