###################################################################
# 11) Test de Johansen et sélection du rang de cointégration
###################################################################

Y <- cbind(log_PIB_ts, log_rd_ts)
colnames(Y) <- c("log_PIB", "log_RD")

# lag.max = 2 car T ≈ 18 obs annuelles (règle T^1/3 ≈ 2.6)
lag_select <- vars::VARselect(Y, lag.max = 2, type = "const")
lag_select$selection

# SC sur petit échantillon + sécurité min = 2 pour ca.jo
p <- max(as.numeric(lag_select$selection["SC(n)"]), 2)
p  

cat("\n===== Test de Johansen (trace) =====\n")
joh_trace <- urca::ca.jo(Y, type = "trace", ecdet = "const", K = p)
summary(joh_trace)

###################################################################
# 12) Estimation du VECM (rang r = 1)
###################################################################

# Estimation du VECM avec la méthode de Johansen
vecm <- urca::cajorls(joh_trace, r = 1)

# Résumé de la régression (partie RLM)
summary(vecm$rlm)

# Affichage du vecteur de cointégration
cat("\n===== Vecteur de cointégration =====\n")
joh_trace@V

###################################################################
# 13) Représentation VAR du VECM — IRF et FEVD
###################################################################

# Transformation du VECM en VAR pour IRF et FEVD
vecm_var <- vars::vec2var(joh_trace, r = 1)

# IRF : choc sur log_R&D → réponse log_PIB
irf_gdp <- vars::irf(
  vecm_var,
  impulse  = "log_RD",
  response = "log_PIB",
  n.ahead  = 10,
  boot     = TRUE
)

# IRF : choc sur log_PIB → réponse log_R&D
irf_rd <- vars::irf(
  vecm_var,
  impulse  = "log_PIB",
  response = "log_RD",
  n.ahead  = 10,
  boot     = TRUE
)

# Ouvrir une nouvelle fenêtre graphique
dev.new()
plot(irf_gdp, main = "IRF : Choc sur log(R&D) → log(PIB UE27)")
plot(irf_rd, main = "IRF : Choc sur log(PIB UE27) → log(R&D)")

# FEVD : contribution des chocs aux erreurs de prévision
fevd_res <- vars::fevd(vecm_var, n.ahead = 10)
plot(fevd_res)

###################################################################
# 14) Tests de validation des résidus du VECM
###################################################################

# Test d’autocorrélation des résidus (Portmanteau)
serial_test <- vars::serial.test(vecm_var, lags.pt = 5, type = "PT.asymptotic")
serial_test

# Test de normalité des résidus
norm_test <- vars::normality.test(vecm_var)
norm_test

# Test ARCH multivarié sur les résidus
arch_test <- vars::arch.test(vecm_var, lags.multi = 5)
arch_test
