##################################################################
# 2) Séries log et tendances déterministes
##################################################################

fr_annuel <- fr_annuel %>%
  mutate(
    t  = row_number(),
    t2 = t^2
  )

fit_lin  <- lm(lratio ~ t,      data = fr_annuel)
fit_quad <- lm(lratio ~ t + t2, data = fr_annuel)

fr_annuel <- fr_annuel %>%
  mutate(
    trend_lin  = predict(fit_lin),
    trend_quad = predict(fit_quad)
  )

ggplot(fr_annuel, aes(x = date)) +
  geom_line(aes(y = lratio,     color = "Log(PIB réel)"),       alpha = 0.7) +
  geom_line(aes(y = trend_lin,   color = "Tendance linéaire")) +
  geom_line(aes(y = trend_quad,  color = "Tendance quadratique")) +
  labs(title = "Tendances déterministes du PIB réel UE27",
       y = "log(PIB réel)", x = "Année") +
  theme_minimal() +
  theme(legend.position = "bottom")

##################################################################
# 3) Filtres cycliques
##################################################################

# HP
hp <- hpfilter(fr_annuel$lratio, freq = 100)
fr_annuel$hp_trend <- hp$trend
fr_annuel$hp_cycle <- hp$cycle

# BK
bk <- bkfilter(fr_annuel$lratio, pl = 2, pu = 8, drift = FALSE)
fr_annuel$bk_trend <- bk$trend
fr_annuel$bk_cycle <- bk$cycle

# CF
cf <- cffilter(fr_annuel$lratio, pl = 2, pu = 8, root = TRUE, drift = FALSE, type = "asymmetric")
fr_annuel$cf_trend <- cf$trend
fr_annuel$cf_cycle <- cf$cycle

# Hamilton
h <- 2

df_h <- fr_annuel %>%
  mutate(
    y_lead = lead(lratio, h),
    y_lag0 = lratio,
    y_lag1 = lag(lratio, 1),
    y_lag2 = lag(lratio, 2),
    y_lag3 = lag(lratio, 3)
  ) %>%
  filter(!is.na(y_lead), !is.na(y_lag3)) 

# Estimation
ham_fit <- lm(y_lead ~ y_lag0 + y_lag1 + y_lag2 + y_lag3, data = df_h)

# PRÉDICTION dans un vecteur séparé
ham_pred <- predict(ham_fit)

# Ajout propre
ham_tr <- df_h %>%
  dplyr::select(date) %>%
  mutate(
    ham_trend = ham_pred,
    ham_cycle = residuals(ham_fit)
  )

# Join final
fr_annuel <- fr_annuel %>%
  left_join(ham_tr, by = "date") %>%
  arrange(date)

# ---- Comparaison des tendances ----
trend_long <- fr_annuel %>%
  dplyr::select(date, hp_trend, bk_trend, cf_trend, ham_trend) %>%
  tidyr::pivot_longer(-date, names_to = "Méthode", values_to = "trend") %>%
  dplyr::mutate(Méthode = dplyr::recode(Méthode,
                                        hp_trend  = "Tendance HP",
                                        bk_trend  = "Tendance BK",
                                        cf_trend  = "Tendance CF",
                                        ham_trend = "Tendance Hamilton"
  ))

print(
  ggplot() +
    geom_line(data = fr_annuel,   aes(date, lratio), alpha = 0.3) +
    geom_line(data = trend_long, aes(date, trend, color = Méthode, linetype = Méthode), linewidth = 1) +
    labs(title = "Tendances du PIB réel UE27 : HP, BK, CF, Hamilton",
         x = NULL, y = "log(PIB réel)", color = NULL, linetype = NULL) +
    theme_minimal() +
    theme(legend.position = "bottom")
)

