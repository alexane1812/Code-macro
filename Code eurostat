eg_reg   <- lm(log_PIB_ts ~ log_rd_ts)
summary(eg_reg)

resid_eg <- residuals(eg_reg)

cat("\n===== ADF — Résidus Engle–Granger =====\n")
adf_eg <- ur.df(resid_eg, type = "none", lags = 4)
