getSymbols("CLVMNACSCAB1GQEU272020", src = "FRED")  

# Création d’un tableau « propre » (tibble) nommé "fr"
fr <- tibble(
  date  = as.Date(index(CLVMNACSCAB1GQEU272020)),
  ratio = as.numeric(CLVMNACSCAB1GQEU272020)       # conversion en proportion (plus en % du PIB)
) |>
  arrange(date) |>                          # Optionnel : ordonner chronologiquement (bonne pratique avant graphes/joins)
  distinct(date, .keep_all = TRUE) |>       # Optionnel : supprimer les doublons de dates (garder la 1re occurrence)
  mutate(
    lratio = log(ratio),
    yq     = as.yearqtr(date)
  )

# Séries trimestrielles (niveaux et logs)
ratio_ts  <- ts(fr$ratio, start = c(year(min(fr$date)), quarter(min(fr$date))), frequency = 4)
lratio_ts <- ts(fr$lratio, start = c(year(min(fr$date)), quarter(min(fr$date))), frequency = 4)

# Séries annuelles (niveaux et logs)
ratio_ann_ts  <- aggregate(ratio_ts,  nfrequency = 1, FUN = last)
lratio_ann_ts <- aggregate(lratio_ts, nfrequency = 1, FUN = last) 

# Conversion en dataframe
fr_annuel <- tibble(
  annee  = time(ratio_ann_ts),
  ratio  = as.numeric(ratio_ann_ts),
  lratio = as.numeric(lratio_ann_ts)
) |>
  mutate(
    date = as.Date(paste0(floor(annee), "-01-01"))
  )

