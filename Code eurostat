# Fonction d'interprétation ADF
interpret_adf <- function(adf_obj) {
  stat <- adf_obj@teststat[1]
  crit <- adf_obj@cval[1, "5pct"]
  
  if (stat < crit) {
    return("Stationnaire (rejette H0)")
  } else {
    return("Non stationnaire (ne rejette pas H0)")
  }
}

# Fonction d'interprétation PP
interpret_pp <- function(pp_obj) {
  if (pp_obj$p.value < 0.05) {
    return("Stationnaire (rejette H0)")
  } else {
    return("Non stationnaire (ne rejette pas H0)")
  }
}

# Fonction d'interprétation KPSS
interpret_kpss <- function(kpss_obj) {
  if (kpss_obj$p.value < 0.05) {
    return("Non stationnaire (rejette H0)")
  } else {
    return("Stationnaire (ne rejette pas H0)")
  }
}


