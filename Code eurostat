# **7) Chargement proxy vert + construction**

```{r}
rd <- read_excel("C:/Users/Lucas/Downloads/Investissement.xlsx", sheet = "R&D")
brevets <- read_excel("C:/Users/Lucas/Downloads/Investissement.xlsx", sheet = "brevets")

data_proxy <- rd %>%
  dplyr::inner_join(brevets, by = c("TIME_PERIOD", "geo")) %>%
  dplyr::rename(
    rd_valeur      = `valeur normalisée`,
    brevets_valeur = `obs normalisées brevets`
  ) %>%
  dplyr::mutate(
    rd_norm       = as.numeric(scale(rd_valeur)),
    brevets_norm  = as.numeric(scale(brevets_valeur)),
    rd      = rd_norm,                        # R&D seul
    proxy     = 0.5 * rd_norm + 0.5 * brevets_norm,  # Proxy
    brevets = brevets_norm                    # Brevets seul
  ) %>%
  dplyr::group_by(TIME_PERIOD) %>%
  dplyr::summarise(
    rd      = mean(rd, na.rm = TRUE),
    proxy     = mean(proxy, na.rm = TRUE),
    brevets = mean(brevets, na.rm = TRUE),
    .groups = "drop"
  )

pib <- fr_annuel %>%
  dplyr::transmute(TIME_PERIOD = lubridate::year(date), PIB = ratio)

# Fusionner les données
data_final <- data_proxy %>%
  inner_join(pib, by = "TIME_PERIOD")

# Mettre les données en format long
data_long <- data_final %>%
  pivot_longer(
    cols = c(rd, proxy, brevets),
    names_to = "proxy_type",
    values_to = "proxy_value"
  )

# Graphiques côte à côte
ggplot(data_long, aes(x = proxy_value, y = PIB)) +
  geom_point(color = "steelblue") +
  geom_smooth(method = "lm", color = "darkred", se = FALSE) +
  facet_wrap(~ proxy_type, scales = "free_x") +
  labs(
    title = "Effet comparé du proxy et des données seules sur le PIB UE27",
    x = "Valeur du proxy",
    y = "PIB réel UE27"
  ) +
  theme_minimal()
```

# **8) Passage en log pour le VAR/VECM**

```{r}
data_final <- data_final %>%
  dplyr::arrange(TIME_PERIOD) %>%
  dplyr::mutate(
    log_PIB   = log(PIB),
    log_rd = log(rd - min(rd) + 1)   # décalage si valeurs négatives
  )

start_yr <- min(data_final$TIME_PERIOD)

log_PIB_ts   <- ts(data_final$log_PIB,   start = start_yr, frequency = 1)
log_rd_ts <- ts(data_final$log_rd, start = start_yr, frequency = 1)
```

